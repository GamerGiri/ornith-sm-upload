# Meta (FB + Insta)
INSTAGRAM_CLIENT_ID=your_instagram_client_id
INSTAGRAM_CLIENT_SECRET=your_instagram_secret
FACEBOOK_ACCESS_TOKEN=your_initial_fb_access_token
META_APP_ID=your_meta_app_id_for_loli_token

# TikTok (if available)
TIKTOK_ACCESS_TOKEN=your_tiktok_api_access_token

# YouTube
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_SECRET=your_youtube_secret

# OAuth Redirect URIs (Must match exactly in developer dashboards!)
FB_REDIRECT_URI=http://YOUR_RENDERS_URL/login/facebook
INSTA_REDIRECT_URI=http://YOUR_RENDERS_URL/login/instagram
YT_REDIRECT_URI=http://YOUR_RENDERS_URL/login/youtube
THREADS_REDIRECT_URI=http://YOUR_RENDERS_URL/login/threads

# Paths
UPLOAD_DIR=./uploads
TOKEN_DIR=./tokens
